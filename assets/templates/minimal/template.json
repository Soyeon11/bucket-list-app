{
  "name": "minimal",
  "display_name": "미니멀",
  "description": "깔끔하고 모던한 미니멀리즘 스타일. 음식, 문화, 일상 콘텐츠에 적합합니다.",
  "version": "1.0.0",

  "background": {
    "type": "solid",
    "color": "#F5F5F5",
    "intro_color": "#FFFFFF",
    "outro_color": "#FFFFFF",
    "gradient": null
  },

  "text_boxes": {
    "title": {
      "x": 540,
      "y": 864,
      "width": 900,
      "height": 200,
      "anchor": "center",
      "font_family": "NotoSansKR-Bold",
      "font_size": 48,
      "font_color": "#1A1A1A",
      "font_weight": "bold",
      "line_spacing": 1.3,
      "max_lines": 3,
      "text_align": "center",
      "background_color": null,
      "background_padding": null,
      "shadow": null,
      "animation": {
        "type": "fade_in",
        "duration": 0.6,
        "delay": 0.2
      }
    },
    "caption": {
      "x": 540,
      "y": 1689,
      "width": 1000,
      "height": 120,
      "anchor": "center",
      "font_family": "NotoSansKR-Regular",
      "font_size": 24,
      "font_color": "#333333",
      "font_weight": "regular",
      "line_spacing": 1.4,
      "max_lines": 2,
      "text_align": "center",
      "background_color": [255, 255, 255, 0.85],
      "background_padding": {
        "top": 12,
        "right": 20,
        "bottom": 12,
        "left": 20
      },
      "background_border_radius": 8,
      "shadow": null,
      "animation": {
        "type": "slide_up",
        "duration": 0.4,
        "delay": 0.1
      }
    },
    "outro_message": {
      "x": 540,
      "y": 880,
      "width": 900,
      "height": 160,
      "anchor": "center",
      "font_family": "NotoSansKR-Bold",
      "font_size": 40,
      "font_color": "#1A1A1A",
      "font_weight": "bold",
      "text_align": "center",
      "background_color": null,
      "shadow": null
    },
    "branding": {
      "x": 540,
      "y": 1820,
      "width": 700,
      "height": 60,
      "anchor": "center",
      "font_family": "NotoSansKR-Regular",
      "font_size": 18,
      "font_color": "#888888",
      "font_weight": "regular",
      "text_align": "center",
      "text": "Bucket List App으로 제작",
      "background_color": null,
      "shadow": null
    }
  },

  "media_area": {
    "x": 0,
    "y": 0,
    "width": 1080,
    "height": 1920,
    "fit": "cover",
    "position": "center",
    "photo_duration": 3.0,
    "photo_max_duration": 5.0,
    "video_max_duration": 15.0,
    "ken_burns": {
      "enabled": true,
      "scale_start": 1.0,
      "scale_end": 1.05,
      "direction": "random"
    }
  },

  "transition": {
    "type": "fade",
    "duration": 0.5,
    "easing": "ease_in_out",
    "intro_transition": {
      "type": "dissolve",
      "duration": 0.4
    },
    "outro_transition": {
      "type": "dissolve",
      "duration": 0.4
    }
  },

  "overlay": {
    "layers": [
      {
        "name": "top_gradient",
        "type": "gradient",
        "direction": "top_to_bottom",
        "start_color": [0, 0, 0, 0.3],
        "end_color": [0, 0, 0, 0.0],
        "start_y": 0,
        "end_y": 384,
        "z_index": 10
      },
      {
        "name": "bottom_gradient",
        "type": "gradient",
        "direction": "bottom_to_top",
        "start_color": [0, 0, 0, 0.4],
        "end_color": [0, 0, 0, 0.0],
        "start_y": 1920,
        "end_y": 1344,
        "z_index": 10
      }
    ]
  },

  "color_grading": {
    "enabled": false,
    "saturation": 1.0,
    "brightness": 1.0,
    "contrast": 1.0,
    "color_temperature": 0
  }
}
